# Environment Configuration
DJANGO_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# SMTP Configuration (for email sending)
SMTP_ENCRYPTION_KEY=your_fernet_encryption_key_here

# Server credential encryption (generate a separate Fernet key)
SERVER_CREDENTIAL_ENCRYPTION_KEY=your_server_credential_fernet_key_here
SSH_CONNECTION_TIMEOUT=30
GIT_CREDENTIAL_ENCRYPTION_KEY=your_git_credential_fernet_key_here
ENVIRONMENT_VARIABLE_ENCRYPTION_KEY=your_environment_variable_fernet_key_here
GIT_OPERATION_TIMEOUT=120
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
DEPLOYMENT_COMMAND_TIMEOUT=600
DEPLOYMENT_HEALTH_TIMEOUT=120
DOCKER_ACTION_TIMEOUT=60
DOCKER_STOP_TIMEOUT=10
DOCKER_LOG_MAX_LINES=1000
DOCKER_LOG_MAX_CHARACTERS=200000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security (Production only)
SECURE_SSL_REDIRECT=False
